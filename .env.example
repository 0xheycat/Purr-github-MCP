# Required by most hosts. Manufact usually injects PORT automatically.
PORT=3000
HOST=0.0.0.0

# Auth mode:
# - passthrough: Notion/agent sends Authorization: Bearer <GitHub PAT>; this token is used for GitHub calls.
# - server_token: Notion/agent sends SERVER_TOKEN; the server uses GITHUB_TOKEN for GitHub calls.
AUTH_MODE=passthrough
SERVER_TOKEN=
GITHUB_TOKEN=

# Optional safety controls.
# Comma-separated owner/repo allowlist. Empty = all repos allowed by the caller's GitHub token.
ALLOWED_REPOS=
PROTECTED_BRANCHES=main,master,production,staging,release
BRANCH_PREFIXES=feat/,fix/,docs/,chore/,refactor/,test/,perf/
MAX_FILES_PER_COMMIT=5
MAX_BYTES_PER_COMMIT=50000
MAX_BYTES_PER_FILE=30000

# CORS. For production, replace * with your Notion/client origin if needed.
CORS_ORIGIN=*
