# Required by most hosts. Manufact usually injects PORT automatically.
PORT=3000
HOST=0.0.0.0

# Auth mode:
# - passthrough: Notion/agent sends Authorization: Bearer <GitHub PAT>; this token is used for GitHub calls.
# - server_token: Notion/agent sends SERVER_TOKEN; the server uses GITHUB_TOKEN for GitHub calls.
AUTH_MODE=passthrough
SERVER_TOKEN=
GITHUB_TOKEN=

# OAuth protected-resource discovery for ChatGPT Apps and remote MCP clients.
# This does not replace bearer auth; it lets clients discover how to obtain and send a bearer access token.
# PUBLIC_BASE_URL should be the public origin that serves this deployment, e.g. https://mcp.pursr.xyz.
# OAUTH_RESOURCE_URL should normally be https://your-host/mcp. Empty = PUBLIC_BASE_URL + /mcp.
# OAUTH_AUTHORIZATION_SERVERS must point to your OAuth authorization server issuer(s) when enabling a login flow.
PUBLIC_BASE_URL=
OAUTH_RESOURCE_URL=
OAUTH_AUTHORIZATION_SERVERS=
OAUTH_SCOPES_SUPPORTED=repo,read:user,user:email
OAUTH_RESOURCE_NAME=Purr GitHub MCP
OAUTH_REALM=purr-github-mcp

# Internal port used by the OAuth wrapper to run the original MCP server on loopback.
# Leave empty unless your host reserves PORT+1.
OAUTH_UPSTREAM_PORT=
OAUTH_UPSTREAM_HOST=127.0.0.1

# Optional safety controls.
# Comma-separated owner/repo allowlist. Empty = all repos allowed by the caller's GitHub token.
ALLOWED_REPOS=

# HTTP JSON-RPC request body cap in bytes. Keep small for normal MCP use.
# Raise only for inline text commits; large/binary files should use source_url ingestion.
# 0 = unlimited at the server layer, but your host/proxy may still cap requests.
REQUEST_BODY_LIMIT=1000000

# GitHub API endpoint. Leave default for production; tests can point this at a mock.
GITHUB_API_BASE=https://api.github.com

# Branch/path safety.
# Empty PROTECTED_BRANCHES disables branch protection checks in this server.
# Empty BRANCH_PREFIXES disables required prefixes for create_branch/create_branch_and_commit.
# ALLOW_PROTECTED_WRITES=true lets write tools target protected names listed below.
# ALLOW_WORKFLOW_WRITES=true allows writes under .github/workflows/.
# ALLOW_REPO_CREATE=true enables create_repository for public/private repos.
PROTECTED_BRANCHES=main,master,production,staging,release
BRANCH_PREFIXES=feat/,fix/,docs/,chore/,refactor/,test/,perf/
ALLOW_PROTECTED_WRITES=false
ALLOW_WORKFLOW_WRITES=false
ALLOW_REPO_CREATE=false

# Commit limits. 0 = unlimited/disabled for this server.
# GitHub blobs still have a hard 100000000-byte API limit; use Git LFS above that.
MAX_FILES_PER_COMMIT=0
MAX_BYTES_PER_COMMIT=0
MAX_BYTES_PER_FILE=100000000

# Binary support. Images are allowed by default; archives/db/key/pdf stay blocked
# unless ALLOW_BINARY=true.
ALLOW_IMAGES=true
ALLOW_BINARY=false

# CORS. For production, replace * with your Notion/client origin if needed.
CORS_ORIGIN=*
